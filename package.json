  "type": "module",
  "description": "InFocus Family CineLog - Die ultimative AI-Watchlist PWA",
  "main": "index.tsx",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
